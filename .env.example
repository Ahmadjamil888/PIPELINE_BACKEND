# Pipeline AI DevOps Platform - Environment Configuration

# ==================== Daytona Configuration ====================
# API key for Daytona workspace management
DAYTONA_API_KEY=your_daytona_api_key_here

# Daytona API URL (default: https://api.daytona.io/v1)
DAYTONA_API_URL=https://api.daytona.io/v1

# ==================== Vercel Configuration ====================
# Vercel API token for deployments
VERCEL_TOKEN=your_vercel_token_here

# Optional: Vercel Team ID (for team deployments)
# VERCEL_TEAM_ID=your_team_id

# ==================== Render Configuration ====================
# Render API key for deployments
RENDER_API_KEY=your_render_api_key_here

# ==================== Database Configuration ====================
# PostgreSQL connection string (if using external database)
# DATABASE_URL=postgresql://user:password@localhost:5432/pipeline

# ==================== Security Configuration ====================
# JWT secret for authentication
JWT_SECRET=your_jwt_secret_here_generate_a_strong_random_string

# API key for internal service communication
API_KEY=your_internal_api_key

# ==================== Application Configuration ====================
# Application environment
ENVIRONMENT=development

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Server port
PORT=8000

# Server host
HOST=0.0.0.0

# ==================== AI Configuration (Optional) ====================
# OpenAI API key (for AI agent capabilities)
# OPENAI_API_KEY=your_openai_api_key

# Anthropic API key (for Claude integration)
# ANTHROPIC_API_KEY=your_anthropic_api_key

# ==================== Redis Configuration (Optional) ====================
# Redis URL for caching and job queues
# REDIS_URL=redis://localhost:6379/0

# ==================== Monitoring (Optional) ====================
# Sentry DSN for error tracking
# SENTRY_DSN=your_sentry_dsn
